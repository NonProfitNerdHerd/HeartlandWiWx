---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { getPageBySlug, getSiteSettings } from '../lib/content';

const page = getPageBySlug('home');

if (!page) {
	throw new Error('Missing home page content at src/content/pages/home.md');
}

const settings = getSiteSettings();
---

<Layout
	title={page.seoTitle || `${settings.siteTitle} | Midwest Storm Chasing`}
	description={page.description || page.seoDescription || settings.tagline}
>
	<Nav slot="nav" />

	<main>
		{
			settings.liveStreamEmbedUrl ? (
				<section class="live-stream">
					<h2>Live Stream</h2>
					<iframe
						src={settings.liveStreamEmbedUrl}
						title="Heartland Chasers Live Stream"
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
						allowfullscreen
					/>
				</section>
			) : null
		}
		<div class="cms-content" set:html={page.html} />
	</main>
</Layout>
