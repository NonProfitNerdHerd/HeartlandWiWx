---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { getPageBySlug, getRoutablePages } from '../lib/content';

export function getStaticPaths() {
	return getRoutablePages().map((page) => ({
		params: { slug: page.slug },
	}));
}

const slug = Astro.params.slug ?? '';
const page = getPageBySlug(slug);

if (!page) {
	return new Response('Not Found', { status: 404 });
}
---

<Layout title={page.seoTitle || page.title} description={page.seoDescription}>
	<Nav slot="nav" />
	<main>
		<div class="cms-content" set:html={page.html} />
	</main>
</Layout>
