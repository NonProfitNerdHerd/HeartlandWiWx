---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import PageEditor from '../../../components/admin/PageEditor';
import { getGlobalBlocks } from '../../../lib/global-blocks';
import type { PageDocument } from '../../../types/blocks';

const globalBlocks = await getGlobalBlocks();
const globalBlockOptions = (globalBlocks.config?.blocks ?? []).map((b) => ({ id: b.id, name: b.name }));

const newDoc: PageDocument = {
	meta: {
		title: '',
		slug: '',
		seoTitle: '',
		description: '',
		published: false,
		draft: true,
		featuredImage: '',
		template: 'default',
		author: '',
		publishDate: new Date().toISOString().slice(0, 10),
		updatedAt: new Date().toISOString().slice(0, 10),
	},
	blocks: [],
};
---

<AdminLayout title="New Page" activeTab="pages" wide>
	<PageEditor client:only="react" initialDocument={newDoc} originalSlug="new" globalBlockOptions={globalBlockOptions} />
</AdminLayout>

<style is:global>
	@import '../../../styles/gutenberg.css';
</style>
