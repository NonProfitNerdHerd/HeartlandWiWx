---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="New Page">
	<h1>New Page</h1>
	<p class="admin-help">Create a Markdown page and save it to GitHub. The public site updates after Vercel redeploys.</p>

	<form id="page-form" class="admin-form">
		<label>
			Title
			<input type="text" name="title" required />
		</label>
		<label>
			Slug
			<input type="text" name="slug" pattern="[a-z0-9]+(-[a-z0-9]+)*" required />
		</label>
		<label>
			SEO Title
			<input type="text" name="seoTitle" />
		</label>
		<label>
			Meta Description
			<input type="text" name="description" />
		</label>
		<label class="admin-checkbox">
			<input type="checkbox" name="published" checked />
			Published
		</label>
		<label>
			Body (Markdown)
			<textarea name="body" placeholder="# Page title&#10;&#10;Your content here..."></textarea>
		</label>
		<div id="form-message" hidden></div>
		<div class="admin-actions">
			<button class="admin-button" type="submit">Save Page</button>
			<a class="admin-button-secondary" href="/admin/pages">Cancel</a>
		</div>
	</form>
</AdminLayout>

<script>
	const form = document.getElementById('page-form') as HTMLFormElement;
	const message = document.getElementById('form-message') as HTMLDivElement;
	const titleInput = form.elements.namedItem('title') as HTMLInputElement;
	const slugInput = form.elements.namedItem('slug') as HTMLInputElement;
	const seoTitleInput = form.elements.namedItem('seoTitle') as HTMLInputElement;

	let slugEdited = false;

	slugInput.addEventListener('input', () => {
		slugEdited = true;
	});

	titleInput.addEventListener('input', () => {
		if (slugEdited) return;
		slugInput.value = titleInput.value
			.toLowerCase()
			.trim()
			.replace(/[^a-z0-9]+/g, '-')
			.replace(/^-+|-+$/g, '');
	});

	titleInput.addEventListener('input', () => {
		if (!seoTitleInput.value) {
			seoTitleInput.placeholder = titleInput.value;
		}
	});

	form.addEventListener('submit', async (event) => {
		event.preventDefault();
		message.hidden = true;

		const formData = new FormData(form);
		const payload = {
			title: String(formData.get('title') ?? ''),
			slug: String(formData.get('slug') ?? ''),
			seoTitle: String(formData.get('seoTitle') ?? '') || String(formData.get('title') ?? ''),
			description: String(formData.get('description') ?? ''),
			body: String(formData.get('body') ?? ''),
			published: formData.get('published') === 'on',
		};

		const response = await fetch('/api/pages/new', {
			method: 'PUT',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(payload),
		});

		const result = await response.json();
		if (!response.ok) {
			message.textContent = result.error || 'Failed to save page.';
			message.className = 'admin-message error';
			message.hidden = false;
			return;
		}

		window.location.href = `/admin/pages/${result.slug}`;
	});
</script>
