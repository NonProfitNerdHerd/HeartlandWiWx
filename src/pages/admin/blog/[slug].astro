---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import ContentEditor from '../../../components/admin/ContentEditor';
import { getPostDocument } from '../../../lib/blog-document';
import { getGlobalBlocks } from '../../../lib/global-blocks';

const slug = Astro.params.slug ?? '';
const post = await getPostDocument(slug);
const globalBlocks = await getGlobalBlocks();

if (!post) {
	return Astro.redirect('/admin/blog');
}

const globalBlockOptions = (globalBlocks.config?.blocks ?? []).map((b) => ({ id: b.id, name: b.name }));
---

<AdminLayout title={`Edit ${post.doc.meta.title}`} activeTab="blog" wide>
	<ContentEditor
		client:only="react"
		contentType="post"
		initialDocument={post.doc}
		originalSlug={slug}
		backUrl="/admin/blog"
		globalBlockOptions={globalBlockOptions}
	/>
</AdminLayout>

<style is:global>
	@import '../../../styles/gutenberg.css';
</style>
