---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import ContentEditor from '../../../components/admin/ContentEditor';
import { getGlobalBlocks } from '../../../lib/global-blocks';
import type { PostDocument } from '../../../types/blocks';

const globalBlocks = await getGlobalBlocks();
const globalBlockOptions = (globalBlocks.config?.blocks ?? []).map((b) => ({ id: b.id, name: b.name }));

const newDoc: PostDocument = {
	meta: {
		title: '',
		slug: '',
		seoTitle: '',
		description: '',
		published: false,
		draft: true,
		featuredImage: '',
		author: '',
		publishDate: new Date().toISOString().slice(0, 10),
		updatedAt: new Date().toISOString().slice(0, 10),
		excerpt: '',
		categories: [],
		tags: [],
	},
	blocks: [],
};
---

<AdminLayout title="New Blog Post" activeTab="blog" wide>
	<ContentEditor
		client:only="react"
		contentType="post"
		initialDocument={newDoc}
		originalSlug="new"
		backUrl="/admin/blog"
		globalBlockOptions={globalBlockOptions}
	>
		<div slot="fallback" class="gb-editor-loading">Loading editor…</div>
	</ContentEditor>
</AdminLayout>

<style is:global>
	@import '../../../styles/gutenberg.css';
</style>
