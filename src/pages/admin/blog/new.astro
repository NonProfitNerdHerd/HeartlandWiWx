---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="New Blog Post" activeTab="blog">
	<h1>New Blog Post</h1>
	<p class="admin-help">Create a chase report or blog post. It will appear at `/chase-reports/your-slug` after deploy.</p>

	<form id="blog-form" class="admin-form">
		<label>
			Title
			<input type="text" name="title" required />
		</label>
		<label>
			Slug
			<input type="text" name="slug" pattern="[a-z0-9]+(-[a-z0-9]+)*" required />
		</label>
		<label>
			Date
			<input type="date" name="date" required />
		</label>
		<label>
			Excerpt
			<input type="text" name="excerpt" />
		</label>
		<label>
			SEO Title
			<input type="text" name="seoTitle" />
		</label>
		<label>
			Meta Description
			<input type="text" name="description" />
		</label>
		<label class="admin-checkbox">
			<input type="checkbox" name="published" checked />
			Published
		</label>
		<label>
			Body (Markdown)
			<textarea name="body" placeholder="## Forecast&#10;&#10;Your post content here..."></textarea>
		</label>
		<div id="form-message" hidden></div>
		<div class="admin-actions">
			<button class="admin-button" type="submit">Save Post</button>
			<a class="admin-button-secondary" href="/admin/blog">Cancel</a>
		</div>
	</form>
</AdminLayout>

<script>
	const form = document.getElementById('blog-form') as HTMLFormElement;
	const message = document.getElementById('form-message') as HTMLDivElement;
	const titleInput = form.elements.namedItem('title') as HTMLInputElement;
	const slugInput = form.elements.namedItem('slug') as HTMLInputElement;
	const dateInput = form.elements.namedItem('date') as HTMLInputElement;

	dateInput.value = new Date().toISOString().slice(0, 10);

	let slugEdited = false;
	slugInput.addEventListener('input', () => {
		slugEdited = true;
	});

	titleInput.addEventListener('input', () => {
		if (slugEdited) return;
		slugInput.value = titleInput.value
			.toLowerCase()
			.trim()
			.replace(/[^a-z0-9]+/g, '-')
			.replace(/^-+|-+$/g, '');
	});

	form.addEventListener('submit', async (event) => {
		event.preventDefault();
		message.hidden = true;

		const formData = new FormData(form);
		const payload = {
			title: String(formData.get('title') ?? ''),
			slug: String(formData.get('slug') ?? ''),
			date: String(formData.get('date') ?? ''),
			excerpt: String(formData.get('excerpt') ?? ''),
			seoTitle: String(formData.get('seoTitle') ?? '') || String(formData.get('title') ?? ''),
			description: String(formData.get('description') ?? '') || String(formData.get('excerpt') ?? ''),
			body: String(formData.get('body') ?? ''),
			published: formData.get('published') === 'on',
		};

		const response = await fetch('/api/blog/new', {
			method: 'PUT',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(payload),
		});

		const result = await response.json();
		if (!response.ok) {
			message.textContent = result.error || 'Failed to save blog post.';
			message.className = 'admin-message error';
			message.hidden = false;
			return;
		}

		window.location.href = `/admin/blog/${result.slug}`;
	});
</script>
