---
interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/heartland-intercept-logo.png" />
		<link rel="apple-touch-icon" href="/heartland-intercept-logo.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
	</head>
	<body>
		<slot name="nav" />
		<slot />
	</body>
</html>

<style is:global>
	@import '../styles/site.css';

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		font-family: Arial, sans-serif;
		background: #000;
		color: white;
	}
</style>
