---
interface Props {
	title: string;
	activeTab?: 'pages' | 'blog' | 'gallery';
}

const { title, activeTab = 'pages' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="robots" content="noindex, nofollow" />
		<title>{title} | Heartland Chasers Admin</title>
	</head>
	<body>
		<header class="admin-header">
			<div class="admin-header-inner">
				<a class="admin-brand" href="/admin/pages">Heartland Chasers CMS</a>
				<nav class="admin-nav">
					<a href="/" target="_blank" rel="noreferrer">View Site</a>
					<button type="button" id="logout-btn">Log out</button>
				</nav>
			</div>
			<nav class="admin-tabs">
				<a href="/admin/pages" class:list={{ active: activeTab === 'pages' || currentPath.startsWith('/admin/pages') }}>
					Pages
				</a>
				<a href="/admin/blog" class:list={{ active: activeTab === 'blog' || currentPath.startsWith('/admin/blog') }}>
					Blog Posts
				</a>
				<a href="/admin/gallery" class:list={{ active: activeTab === 'gallery' || currentPath.startsWith('/admin/gallery') }}>
					Gallery
				</a>
			</nav>
		</header>
		<main class="admin-main">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	@import '../styles/admin.css';
</style>

<script>
	document.getElementById('logout-btn')?.addEventListener('click', async () => {
		await fetch('/api/auth/logout', { method: 'POST' });
		window.location.href = '/admin/login';
	});
</script>
