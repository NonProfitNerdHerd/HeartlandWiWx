---
interface Props {
	title: string;
	activeTab?: 'pages' | 'blog' | 'gallery' | 'appearance' | 'navigation' | 'site-text' | 'global-blocks' | 'media' | 'forms' | 'form-submissions';
	wide?: boolean;
}

const { title, activeTab = 'pages', wide = false } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="robots" content="noindex, nofollow" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
		<title>{title} | Heartland Chasers Admin</title>
	</head>
	<body class:list={{ 'admin-wide': wide }}>
		<header class="admin-header">
			<div class="admin-header-inner">
				<a class="admin-brand" href="/admin/pages">Heartland Chasers Builder</a>
				<nav class="admin-nav">
					<a href="/" target="_blank" rel="noreferrer">View Site</a>
					<button type="button" id="logout-btn">Log out</button>
				</nav>
			</div>
			<nav class="admin-tabs">
				<span class="admin-tab-group-label">Content</span>
				<a href="/admin/pages" class:list={{ active: activeTab === 'pages' || currentPath.startsWith('/admin/pages') }}>Pages</a>
				<a href="/admin/blog" class:list={{ active: activeTab === 'blog' || currentPath.startsWith('/admin/blog') }}>Blog Posts</a>
				<a href="/admin/gallery" class:list={{ active: activeTab === 'gallery' }}>Gallery</a>
				<a href="/admin/media" class:list={{ active: activeTab === 'media' }}>Media</a>
				<a href="/admin/forms" class:list={{ active: activeTab === 'forms' }}>Forms</a>
				<a href="/admin/form-submissions" class:list={{ active: activeTab === 'form-submissions' }}>Form Submissions</a>
				<span class="admin-tab-group-label">Site</span>
				<a href="/admin/appearance" class:list={{ active: activeTab === 'appearance' }}>Appearance</a>
				<a href="/admin/navigation" class:list={{ active: activeTab === 'navigation' }}>Navigation</a>
				<a href="/admin/site-text" class:list={{ active: activeTab === 'site-text' }}>Site Text</a>
				<a href="/admin/global-blocks" class:list={{ active: activeTab === 'global-blocks' }}>Global Blocks</a>
			</nav>
		</header>
		<main class="admin-main">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	@import '../styles/admin.css';
</style>

<script>
	document.getElementById('logout-btn')?.addEventListener('click', async () => {
		await fetch('/api/auth/logout', { method: 'POST' });
		window.location.href = '/admin/login';
	});
</script>
