---
import { getNavigationForBuild } from '../lib/navigation';

const currentPath = Astro.url.pathname;
const headerNav = getNavigationForBuild('header');
---

<nav>
	<a class="brand" href="/">
		<img src="/logo.png" alt="Heartland Intercept - Severe Weather Chasing" />
	</a>
	{
		headerNav.items.map((item) => {
			const href = item.href;
			const isActive =
				currentPath === href ||
				(href !== '/' && currentPath.startsWith(`${href}/`)) ||
				(href === '/chase-reports' && currentPath.startsWith('/chase-reports'));

			return (
				<a
					href={href}
					class:list={{ active: isActive }}
					target={item.openInNewTab ? '_blank' : undefined}
					rel={item.openInNewTab ? 'noreferrer' : undefined}
				>
					{item.icon ? <span class="nav-icon">{item.icon}</span> : null}
					{item.label}
				</a>
			);
		})
	}
</nav>
