---
import { getMenuPages, getPageHref } from '../lib/content';

const currentPath = Astro.url.pathname;
const menuPages = getMenuPages();
---

<nav>
	<a class="brand" href="/">
		<img src="/logo.png" alt="Heartland Intercept - Severe Weather Chasing" />
	</a>
	{
		menuPages.map((page) => {
			const href = getPageHref(page.slug);
			const isActive =
				currentPath === href ||
				(href !== '/' && currentPath.startsWith(`${href}/`)) ||
				(page.slug === 'chase-reports' && currentPath.startsWith('/chase-reports'));

			return (
				<a href={href} class:list={{ active: isActive }}>
					{page.menuLabel || page.title}
				</a>
			);
		})
	}
</nav>
